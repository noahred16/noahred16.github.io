" Enable syntax highlighting based on file type
syntax on
filetype plugin indent on

" UI and Line Numbers
set number          " Show line numbers
set cursorline      " Highlight the line the cursor is on
set wildmenu        " Visual autocomplete menu for command mode

" Tabs and Indentation
set tabstop=4       " Show existing tabs as 4 spaces
set shiftwidth=4    " Indentation is 4 spaces long
set expandtab       " Convert tabs to spaces automatically
set smartindent     " Automatically insert extra indent when appropriate

" Search Settings
set hlsearch        " Highlight search matches
set incsearch       " Show matches as you type
set ignorecase      " Ignore case when searching...
set smartcase       " ...unless search contains a capital letter

" Performance
set ttyfast         " Speed up screen redrawing

